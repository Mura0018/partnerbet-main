# =========================================================
# PARTNERBET — ENVIRONMENT VARIABLES
# Bu faylni ".env.local" nomi bilan nusxalang va kalitlaringizni
# pastga joylashtiring. Kod yozish shart emas — faqat "=" dan keyin
# qiymatni joylashtiring.
# Vercel'ga deploy qilganda bu qiymatlarni Vercel Dashboard >
# Settings > Environment Variables bo'limiga joylashtirasiz.
# =========================================================

# --- SUPABASE ---
# Supabase.com > loyihangiz > Settings > API bo'limidan oling
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- FOOTBALL DATA PROVIDER ---
# Kalit kerak emas — barcha football ma'lumot provayderlari (API-Football,
# Sportmonks, Football-Data.org) endi to'liq Admin panel orqali sozlanadi:
# Admin > Sozlamalar > API kalitlar. U yerda tanlangan provayder va kalit
# xavfsiz bazada saqlanadi (hech qachon .env yoki kodga yozilmaydi).

# --- CRON (Link Health avtomatik tekshiruvi, Phase 3b) ---
# Ixtiyoriy tasodifiy matn (masalan 32 ta belgidan iborat) — Vercel Cron
# so'rovlarini haqiqiylashtirish uchun. vercel.json'dagi jadval bilan birga
# ishlatiladi.
CRON_SECRET=

# --- SHIFRLASH (Live Streaming provider kalitlari, v1.1.0) ---
# Majburiy — kamida 32 ta tasodifiy belgi (masalan: `openssl rand -hex 32`).
# Streaming provider API kaliti/siri shu kalit bilan shifrlanib saqlanadi
# (AES-256-GCM). Bu qiymatni hech qachon almashtirmang — aks holda avval
# saqlangan barcha shifrlangan kalitlar o'qib bo'lmay qoladi.
ENCRYPTION_KEY=

# --- SAYT SOZLAMALARI ---
NEXT_PUBLIC_SITE_NAME=PartnerBet
NEXT_PUBLIC_SITE_URL=https://couponbet.org
